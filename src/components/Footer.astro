---
const year = new Date().getFullYear();

const techTicker = [
  "React", "Next.js", "Vue.js", "Flutter", "TypeScript",
  "Tailwind CSS", "Astro", "Storybook", "Zustand", "React Query",
  "Zod", "Jest", "Vite", "Node.js", "Firebase", "Dart",
];

const navLinks = [
  { label: "Home",    href: "#" },
  { label: "About",   href: "#about" },
  { label: "Work",    href: "#projects" },
  { label: "Skills",  href: "#skills" },
  { label: "Contact", href: "#contact" },
];
---

<!-- Tech ticker -->
<div class="ticker-section" aria-hidden="true">
  <div class="ticker-track">
    <div class="ticker-tape">
      {[...techTicker, ...techTicker].map((t) => (
        <span class="tick-item">
          <span class="tick-sep">·</span>
          {t}
        </span>
      ))}
    </div>
  </div>
</div>

<!-- Footer -->
<footer class="site-footer">
  <div class="footer-main">
    <div class="footer-brand">
      <div class="footer-name">Dicky Budianto</div>
      <div class="footer-tagline">Frontend Developer — Surabaya, ID</div>
    </div>

    <nav aria-label="Footer navigation">
      <ul class="footer-nav">
        {navLinks.map(({ label, href }) => (
          <li><a href={href}>{label}</a></li>
        ))}
      </ul>
    </nav>
  </div>

  <div class="footer-bottom">
    <div class="footer-copy">
      © {year} Dicky Budianto <span aria-hidden="true">·</span> Built with Astro
    </div>
    <div class="footer-copy">
      Designed &amp; developed with <span class="heart" aria-label="love">♥</span>
    </div>
  </div>
</footer>

<style>
  /* ── Ticker ─── */
  .ticker-section {
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    padding: 13px 0;
    overflow: hidden;
    position: relative;
    z-index: 10;
  }
  .ticker-track { overflow: hidden; }
  .ticker-tape {
    display: flex;
    white-space: nowrap;
    animation: marquee 28s linear infinite;
  }
  .tick-item {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 0 8px;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .tick-sep { color: var(--muted-2); }

  /* ── Footer ─── */
  .site-footer {
    position: relative;
    z-index: 10;
    padding: 36px var(--section-px) 40px;
    background: var(--bg);
  }

  .footer-main {
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 24px;
    margin-bottom: 32px;
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: 22px;
    font-weight: 800;
    color: var(--text);
    letter-spacing: 0.02em;
    margin-bottom: 4px;
  }
  .footer-tagline {
    font-size: 12px;
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  .footer-nav {
    display: flex;
    gap: 28px;
    list-style: none;
    flex-wrap: wrap;
  }
  .footer-nav a {
    font-size: 12px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-nav a:hover { color: var(--accent); }

  .footer-bottom {
    padding-top: 24px;
    border-top: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 12px;
  }
  .footer-copy {
    font-size: 12px;
    color: var(--muted-2);
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .heart { color: var(--accent); }
</style>
