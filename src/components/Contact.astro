---
const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? "";
---

<!-- Orbs for this section -->
<div class="contact-orb contact-orb-1" aria-hidden="true"></div>
<div class="contact-orb contact-orb-2" aria-hidden="true"></div>

<section id="contact" class="contact-section">
  <div class="section-label reveal">Get in Touch</div>

  <h2 class="contact-heading reveal">
    GOT A<br />
    <span>PROJECT</span><br />
    <span class="dim">IN MIND?</span>
  </h2>

  <p class="contact-sub reveal">
    I'm available for freelance projects and full-time roles.
    Let's build something worth showing off.
  </p>

  <div class="contact-grid reveal">
    <!-- Form -->
    <form class="contact-form" id="contact-form" novalidate>
      <!-- Web3Forms config -->
      <input type="hidden" name="access_key" value={web3formsKey} />
      <input type="hidden" name="subject" value="New message from your portfolio" />
      <input type="hidden" name="from_name" value="Portfolio Contact Form" />
      <!-- Honeypot spam trap (must stay empty) -->
      <input
        type="checkbox"
        name="botcheck"
        class="hidden-honeypot"
        tabindex="-1"
        autocomplete="off"
        aria-hidden="true"
      />

      <div class="field">
        <input type="text" id="c-name" name="name" placeholder=" " required autocomplete="name" />
        <label for="c-name">Your Name</label>
      </div>
      <div class="field">
        <input type="email" id="c-email" name="email" placeholder=" " required autocomplete="email" />
        <label for="c-email">Email Address</label>
      </div>
      <div class="field">
        <textarea id="c-msg" name="message" placeholder=" " required rows="5"></textarea>
        <label for="c-msg">Your Message</label>
      </div>
      <button class="send-btn" type="submit">
        <span class="send-label">Send Message</span>
        <span class="send-arrow" aria-hidden="true">→</span>
      </button>
      <div class="form-status" id="form-status" role="status" aria-live="polite"></div>
    </form>

    <!-- Info cards -->
    <div class="contact-info">
      <div class="info-card">
        <div class="info-label">Email</div>
        <div class="info-value">
          <a href="mailto:dbudianto9@gmail.com">dbudianto9@gmail.com</a>
        </div>
        <div class="avail-status">
          <span class="avail-dot" aria-hidden="true"></span>
          Available for new projects
        </div>
      </div>
      <div class="info-card">
        <div class="info-label">LinkedIn</div>
        <div class="info-value">
          <a
            href="https://www.linkedin.com/in/dicky-budianto-sugiono-433ba822b/"
            target="_blank"
            rel="noopener noreferrer"
          >
            linkedin.com/in/dickybudianto
          </a>
        </div>
      </div>
      <div class="info-card">
        <div class="info-label">Based In</div>
        <div class="info-value">Surabaya, Indonesia</div>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Orbs ─── */
  .contact-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(140px);
    pointer-events: none;
    z-index: 0;
  }
  .contact-orb-1 {
    width: 500px; height: 500px;
    background: radial-gradient(circle, rgba(0, 229, 204, 0.055), transparent 70%);
    bottom: -100px; left: 50%; transform: translateX(-50%);
  }
  .contact-orb-2 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, rgba(123, 97, 255, 0.045), transparent 70%);
    top: 60px; right: -80px;
  }

  .contact-section {
    position: relative;
    z-index: 10;
    padding: var(--section-py) var(--section-px) calc(var(--section-py) * 0.75);
  }

  .contact-heading {
    font-family: var(--font-display);
    font-size: clamp(44px, 8vw, 96px);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.02em;
    margin-bottom: 24px;
    animation-delay: 0.1s;
  }
  .contact-heading span { color: var(--accent); }
  .contact-heading .dim { color: var(--muted-2); }

  .contact-sub {
    font-size: 16px;
    line-height: 1.75;
    color: var(--muted);
    max-width: 500px;
    margin-bottom: 56px;
    animation-delay: 0.2s;
  }

  /* ── Grid ─── */
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 48px;
    align-items: start;
    animation-delay: 0.3s;
  }
  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
  }

  /* ── Form ─── */
  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 18px;
  }

  .field { position: relative; }
  .field input,
  .field textarea {
    width: 100%;
    background: var(--surface);
    border: 1px solid var(--border);
    color: var(--text);
    font-family: var(--font-body);
    font-size: 15px;
    padding: 20px 18px 8px;
    outline: none;
    border-radius: 2px;
    transition: border-color 0.25s;
    resize: none;
  }
  .field textarea { min-height: 140px; }
  .field input:focus,
  .field textarea:focus { border-color: var(--accent); }

  /* Floating label */
  .field label {
    position: absolute;
    left: 18px;
    top: 14px;
    font-size: 12px;
    letter-spacing: 0.07em;
    text-transform: uppercase;
    color: var(--muted);
    pointer-events: none;
    transition: top 0.2s, font-size 0.2s, color 0.2s;
  }
  .field input:focus ~ label,
  .field input:not(:placeholder-shown) ~ label,
  .field textarea:focus ~ label,
  .field textarea:not(:placeholder-shown) ~ label {
    top: 5px;
    font-size: 9px;
    color: var(--accent);
  }

  .send-btn {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 18px 24px;
    background: var(--accent);
    border: none;
    color: var(--bg);
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    cursor: pointer;
    border-radius: 2px;
    overflow: hidden;
    transition: background 0.25s;
    position: relative;
  }
  .send-btn:hover { background: #00f5da; }
  .send-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .send-arrow {
    font-size: 20px;
    transition: transform 0.25s;
  }
  .send-btn:hover .send-arrow { transform: translateX(5px); }

  .form-status {
    font-size: 13px;
    min-height: 20px;
    color: var(--accent);
    letter-spacing: 0.05em;
  }
  .form-status.error { color: #FF6B6B; }

  /* ── Info cards ─── */
  .contact-info { display: flex; flex-direction: column; gap: 14px; }
  .info-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 22px 26px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.25s;
  }
  .info-card:hover { border-color: rgba(0, 229, 204, 0.2); }
  .info-card::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(90deg, transparent, var(--accent), transparent);
    opacity: 0;
    transition: opacity 0.3s;
  }
  .info-card:hover::before { opacity: 1; }

  .info-label {
    font-size: 10px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 6px;
  }
  .info-value {
    font-family: var(--font-display);
    font-size: 14px;
    font-weight: 600;
    color: var(--text);
  }
  .info-value a {
    color: inherit;
    text-decoration: none;
    transition: color 0.2s;
  }
  .info-value a:hover { color: var(--accent); }

  .avail-status {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 12px;
    color: var(--accent);
    margin-top: 6px;
  }
  .avail-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse-dot 2s ease-in-out infinite;
    box-shadow: 0 0 6px rgba(0, 229, 204, 0.5);
    flex-shrink: 0;
  }

  /* Honeypot — visually hidden, off-screen, not focusable */
  .hidden-honeypot {
    position: absolute !important;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    pointer-events: none;
  }
</style>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const statusEl = document.getElementById("form-status");

  const BTN_DEFAULT_HTML =
    '<span class="send-label">Send Message</span><span class="send-arrow" aria-hidden="true">→</span>';

  function setStatus(message: string, isError = false) {
    if (!statusEl) return;
    statusEl.textContent = message;
    statusEl.className = isError ? "form-status error" : "form-status";
  }

  form?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const btn = form.querySelector<HTMLButtonElement>(".send-btn");
    const formData = new FormData(form);

    // Guard: ensure the access key is present
    if (!formData.get("access_key")) {
      setStatus("Form isn't configured yet. Please email dbudianto9@gmail.com directly.", true);
      return;
    }

    // Native HTML5 validation
    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    if (btn) { btn.disabled = true; btn.textContent = "Sending…"; }
    setStatus("");

    try {
      const payload = Object.fromEntries(formData.entries());
      const res = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          Accept: "application/json",
        },
        body: JSON.stringify(payload),
      });
      const data = await res.json();

      if (res.ok && data.success) {
        setStatus("Message sent! I'll get back to you within 24 hours.");
        form.reset();
      } else {
        setStatus(data.message || "Something went wrong. Please try again or email me directly.", true);
      }
    } catch {
      setStatus("Network error. Please try again or email dbudianto9@gmail.com directly.", true);
    } finally {
      if (btn) { btn.disabled = false; btn.innerHTML = BTN_DEFAULT_HTML; }
    }
  });
</script>
