---
// Hero section — SIGNAL/NOISE design
---

<!-- Dot-grid background -->
<div class="dot-grid" aria-hidden="true"></div>

<!-- Atmospheric orbs -->
<div class="orb orb-1" aria-hidden="true"></div>
<div class="orb orb-2" aria-hidden="true"></div>

<section class="hero" id="hero">
  <div class="hero-label">Frontend Developer</div>

  <h1 class="hero-title">
    <span class="line"><span class="word">CRAFTING</span></span>
    <span class="line"><span class="word accent">INTERFACES</span></span>
    <span class="line"><span class="word dim">THAT MATTER<span class="cursor-blink" aria-hidden="true"></span></span></span>
  </h1>

  <p class="hero-sub reveal">
    I'm Dicky Budianto — building web and mobile experiences that bridge
    design precision with engineering quality. Based in Surabaya, ID.
  </p>

  <div class="hero-actions reveal">
    <a href="#projects" class="btn-primary">View Work ↓</a>
    <a href="#contact" class="btn-ghost">Get in Touch</a>
  </div>

  <!-- Decorative large number -->
  <div class="deco-num" aria-hidden="true">01</div>

  <!-- Scroll hint -->
  <div class="scroll-hint" aria-hidden="true">
    <div class="scroll-line"></div>
    Scroll
  </div>

  <!-- Marquee ticker -->
  <div class="ticker-wrap" aria-hidden="true">
    <div class="ticker">
      <div class="ticker-item">
        <strong>Currently at</strong> Baskit Technology
        <span class="sep">//</span>
        <strong>Open to</strong> New Opportunities
        <span class="sep">//</span>
        React <span class="sep">·</span> Next.js <span class="sep">·</span> Vue <span class="sep">·</span> Flutter <span class="sep">·</span> TypeScript
        <span class="sep">//</span>
        <strong>3+ Years</strong> Building Products
        <span class="sep">//</span>
        <strong>6</strong> Major Projects
        <span class="sep">//</span>
      </div>
      <div class="ticker-item" aria-hidden="true">
        <strong>Currently at</strong> Baskit Technology
        <span class="sep">//</span>
        <strong>Open to</strong> New Opportunities
        <span class="sep">//</span>
        React <span class="sep">·</span> Next.js <span class="sep">·</span> Vue <span class="sep">·</span> Flutter <span class="sep">·</span> TypeScript
        <span class="sep">//</span>
        <strong>3+ Years</strong> Building Products
        <span class="sep">//</span>
        <strong>6</strong> Major Projects
        <span class="sep">//</span>
      </div>
    </div>
  </div>
</section>

<style>
  /* ── Dot-grid ─── */
  .dot-grid {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: radial-gradient(circle, var(--border) 1px, transparent 1px);
    background-size: 32px 32px;
    mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 20%, transparent 100%);
    opacity: 0.45;
  }

  /* ── Orbs ─── */
  .orb {
    position: fixed;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
  }
  .orb-1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, rgba(0, 229, 204, 0.07) 0%, transparent 70%);
    top: -200px;
    left: -100px;
    animation: orb-drift 12s ease-in-out infinite alternate;
  }
  .orb-2 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(123, 97, 255, 0.06) 0%, transparent 70%);
    bottom: -100px;
    right: -100px;
    animation: orb-drift 15s ease-in-out infinite alternate-reverse;
  }

  /* ── Hero section ─── */
  .hero {
    position: relative;
    z-index: 10;
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 120px var(--section-px) 100px;
    overflow: hidden;
  }

  /* Label */
  .hero-label {
    font-size: 11px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: 28px;
    display: flex;
    align-items: center;
    gap: 14px;
    animation: fade-up 0.8s 0.2s ease both;
  }
  .hero-label::before {
    content: '';
    width: 32px;
    height: 1px;
    background: var(--accent);
    flex-shrink: 0;
  }

  /* Title */
  .hero-title {
    font-family: var(--font-display);
    font-size: clamp(56px, 9vw, 124px);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 40px;
  }
  .hero-title .line {
    display: block;
    overflow: hidden;
  }
  .hero-title .word {
    display: inline-block;
    animation: word-reveal 0.9s cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .hero-title .line:nth-child(1) .word { animation-delay: 0.3s; }
  .hero-title .line:nth-child(2) .word { animation-delay: 0.45s; }
  .hero-title .line:nth-child(3) .word { animation-delay: 0.6s; }

  .hero-title .accent { color: var(--accent); }
  .hero-title .dim    { color: var(--muted-2); }

  /* Cursor blink */
  .cursor-blink {
    display: inline-block;
    width: 4px;
    height: 0.8em;
    background: var(--accent);
    margin-left: 6px;
    vertical-align: middle;
    animation: blink 1s step-end infinite;
  }

  /* Sub-text */
  .hero-sub {
    max-width: 480px;
    font-size: 17px;
    line-height: 1.75;
    color: var(--muted);
    margin-bottom: 48px;
    animation-delay: 0.2s;
  }

  /* Actions */
  .hero-actions {
    display: flex;
    align-items: center;
    gap: 16px;
    flex-wrap: wrap;
    animation-delay: 0.35s;
  }

  /* Decorative number */
  .deco-num {
    position: absolute;
    right: var(--section-px);
    bottom: 100px;
    font-family: var(--font-display);
    font-size: clamp(120px, 16vw, 200px);
    font-weight: 800;
    color: transparent;
    -webkit-text-stroke: 1px rgba(26, 34, 54, 0.7);
    line-height: 1;
    user-select: none;
    pointer-events: none;
    animation: fade-up 1s 1.2s ease both;
  }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: 40px;
    left: var(--section-px);
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    animation: fade-up 0.8s 1.4s ease both;
  }
  .scroll-line {
    width: 1px;
    height: 48px;
    background: var(--border);
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
  }
  .scroll-line::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 50%;
    background: var(--accent);
    animation: scroll-drop 2s ease-in-out infinite;
  }

  /* Marquee */
  .ticker-wrap {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    border-top: 1px solid var(--border);
    background: rgba(14, 20, 32, 0.7);
    overflow: hidden;
    padding: 14px 0;
    animation: fade-up 0.8s 1.6s ease both;
  }
  .ticker {
    display: flex;
    white-space: nowrap;
    animation: marquee 22s linear infinite;
  }
  .ticker-item {
    display: flex;
    align-items: center;
    gap: 24px;
    padding: 0 24px;
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .ticker-item strong {
    color: var(--accent);
    font-weight: 500;
  }
  .sep { color: var(--muted-2); }

  /* Mobile */
  @media (max-width: 640px) {
    .deco-num { display: none; }
    .hero-actions { flex-direction: column; align-items: flex-start; }
    .scroll-hint { display: none; }
  }
</style>
