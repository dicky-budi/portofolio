---
import { Image } from "astro:assets";
import profile from "../assets/profile.png";

const experience = [
  {
    company: "PT. Baskit Technology Aplikasi",
    role: "Front End Developer",
    period: "Apr 2025 — Present",
    current: true,
    desc: "Building ERP and supply-chain management tools for SMEs. Shipped inventory, PO, and warehouse modules used daily by operators across multiple locations.",
  },
  {
    company: "PT. Krakatau Karya Abadi",
    role: "Senior Software Engineer I",
    period: "Apr 2022 — Jan 2025",
    current: false,
    desc: "Led frontend for internal dashboards (React) and cross-platform mobile apps (Flutter). Mentored junior devs and established component library standards.",
  },
  {
    company: "PT. Usaha Kreatif Indonesia",
    role: "Junior Front End Developer",
    period: "Okt 2018 — Mar 2022",
    current: false,
    desc: "Developed and maintained web dashboards and Flutter mobile applications for diverse client projects.",
  },
];
---

<section id="about" class="about-section">
  <div class="section-label reveal">About Me</div>

  <div class="bento">
    <!-- Profile card -->
    <div class="card card-profile reveal">
      <div class="avatar-wrap">
        <div class="avatar-glow" aria-hidden="true"></div>
        <div class="avatar-ring" aria-hidden="true"></div>
        <Image
          class="avatar-img"
          src={profile}
          alt="Dicky Budianto"
          width={140}
          height={140}
        />
      </div>
      <div class="profile-name">Dicky Budianto</div>
      <div class="profile-role">Frontend Developer</div>
      <div class="profile-location">
        <span aria-hidden="true">◎</span> Surabaya, Indonesia
      </div>
      <div class="profile-divider" aria-hidden="true"></div>
      <div class="profile-links">
        <a
          href="https://www.linkedin.com/in/dicky-budianto-sugiono-433ba822b/"
          target="_blank"
          rel="noopener noreferrer"
          class="profile-link"
          aria-label="LinkedIn"
        >
          in
        </a>
        <a
          href="mailto:dbudianto9@gmail.com"
          class="profile-link"
          aria-label="Email"
        >
          @
        </a>
      </div>
    </div>

    <!-- Bio card -->
    <div class="card card-bio reveal">
      <h2 class="bio-title">
        I build things that <span>feel</span> as good as they perform.
      </h2>
      <p class="bio-text">
        Frontend developer with <em>7+ years</em> crafting production-grade web and mobile
        applications. I have a design-system obsession and believe great interfaces are built
        at the intersection of <em>engineering precision</em> and <em>visual craft</em>.
        Currently shipping at <em>Baskit Technology</em>, building ERP and supply chain
        tools for SMEs across Indonesia.
      </p>
    </div>

    <!-- Stats card -->
    <div class="card card-stats reveal">
      <div class="stat">
        <div class="stat-num" data-target="7">0<span>+</span></div>
        <div class="stat-label">Years Experience</div>
      </div>
      <div class="stat">
        <div class="stat-num" data-target="6">0</div>
        <div class="stat-label">Major Projects</div>
      </div>
      <div class="stat">
        <div class="stat-num" data-target="35">0<span>+</span></div>
        <div class="stat-label">Skills</div>
      </div>
    </div>

    <!-- Timeline card -->
    <div class="card card-timeline reveal">
      <div class="tl-title">Experience</div>
      <div class="timeline">
        {experience.map((exp, i) => (
          <div class={`tl-item${exp.current ? ' current' : ''}`}>
            <div class="tl-dot" aria-hidden="true"></div>
            <div class="tl-content">
              <div class="tl-company">{exp.company}</div>
              <div class="tl-role">{exp.role}</div>
              <div class="tl-date">{exp.period}</div>
              <div class="tl-desc">{exp.desc}</div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .about-section {
    position: relative;
    z-index: 10;
    padding: var(--section-py) var(--section-px);
  }

  /* ── Bento grid ─── */
  .bento {
    display: grid;
    grid-template-columns: 260px 1fr;
    grid-template-areas:
      "profile bio"
      "profile stats"
      "timeline timeline";
    gap: 14px;
    max-width: 1160px;
    margin-top: 48px;
  }

  @media (max-width: 900px) {
    .bento {
      grid-template-columns: 1fr;
      grid-template-areas:
        "profile"
        "bio"
        "stats"
        "timeline";
    }
  }

  /* ── Card base ─── */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 2px;
    padding: 32px;
    position: relative;
    overflow: hidden;
    transition: border-color 0.3s;
  }
  .card::before {
    content: '';
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(ellipse 60% 40% at 50% 0%, rgba(0, 229, 204, 0.03), transparent);
  }
  .card:hover { border-color: rgba(0, 229, 204, 0.2); }

  /* ── Profile card ─── */
  .card-profile {
    grid-area: profile;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: 40px 28px;
  }

  .avatar-wrap {
    position: relative;
    width: 140px;
    height: 140px;
    margin-bottom: 24px;
    flex-shrink: 0;
  }
  .avatar-glow {
    position: absolute;
    inset: -20px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(0, 229, 204, 0.12), transparent 70%);
    animation: glow-pulse 3s ease-in-out infinite;
  }
  .avatar-ring {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1.5px solid transparent;
    background: linear-gradient(135deg, var(--accent), var(--accent-2)) border-box;
    -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: xor;
    mask-composite: exclude;
    animation: ring-rotate 7s linear infinite;
  }
  .avatar-img {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    object-fit: cover;
    display: block;
  }

  .profile-name {
    font-family: var(--font-display);
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 6px;
  }
  .profile-role {
    font-size: 12px;
    color: var(--accent);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 14px;
  }
  .profile-location {
    font-size: 13px;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 6px;
    justify-content: center;
    margin-bottom: 24px;
  }
  .profile-divider {
    width: 40px;
    height: 1px;
    background: var(--border);
    margin-bottom: 24px;
  }
  .profile-links {
    display: flex;
    gap: 10px;
  }
  .profile-link {
    width: 36px;
    height: 36px;
    border: 1px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    text-decoration: none;
    font-size: 12px;
    font-family: var(--font-display);
    font-weight: 700;
    border-radius: 2px;
    transition: border-color 0.2s, color 0.2s;
  }
  .profile-link:hover { border-color: var(--accent); color: var(--accent); }

  /* ── Bio card ─── */
  .card-bio {
    grid-area: bio;
    padding: 40px;
  }
  .bio-title {
    font-family: var(--font-display);
    font-size: clamp(20px, 2.5vw, 28px);
    font-weight: 700;
    line-height: 1.25;
    margin-bottom: 20px;
    color: var(--text);
  }
  .bio-title span { color: var(--accent); }
  .bio-text {
    font-size: 15px;
    line-height: 1.85;
    color: var(--muted);
  }
  .bio-text em { color: var(--text); font-style: normal; }

  /* ── Stats card ─── */
  .card-stats {
    grid-area: stats;
    display: flex;
    gap: 0;
    padding: 0;
    overflow: hidden;
  }
  .stat {
    flex: 1;
    padding: 28px 24px;
    border-right: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .stat:last-child { border-right: none; }
  .stat-num {
    font-family: var(--font-display);
    font-size: clamp(32px, 4vw, 44px);
    font-weight: 800;
    color: var(--text);
    line-height: 1;
  }
  .stat-num span { color: var(--accent); }
  .stat-label {
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* ── Timeline card ─── */
  .card-timeline {
    grid-area: timeline;
    padding: 36px 40px;
  }
  .tl-title {
    font-size: 11px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 28px;
  }
  .timeline {
    display: flex;
    flex-direction: column;
    position: relative;
  }
  .timeline::before {
    content: '';
    position: absolute;
    left: 7px;
    top: 8px;
    bottom: 8px;
    width: 1px;
    background: var(--border);
  }
  .tl-item {
    display: grid;
    grid-template-columns: 16px 1fr;
    gap: 20px;
    padding-bottom: 28px;
  }
  .tl-item:last-child { padding-bottom: 0; }
  .tl-dot {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    margin-top: 3px;
    background: var(--surface-2);
    border: 2px solid var(--border);
    position: relative;
    z-index: 1;
    flex-shrink: 0;
    transition: border-color 0.3s;
  }
  .tl-item.current .tl-dot {
    background: var(--accent);
    border-color: var(--accent);
    box-shadow: 0 0 16px rgba(0, 229, 204, 0.35);
  }
  .tl-company {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 700;
    color: var(--text);
    margin-bottom: 3px;
  }
  .tl-role { font-size: 12px; color: var(--accent); margin-bottom: 3px; }
  .tl-date { font-size: 12px; color: var(--muted); margin-bottom: 8px; }
  .tl-desc { font-size: 14px; line-height: 1.65; color: var(--muted); }

  @media (max-width: 640px) {
    .card-timeline { padding: 28px 24px; }
    .card-bio { padding: 28px; }
    .card-stats { flex-wrap: wrap; }
    .stat { min-width: 50%; }
  }
</style>

<script>
  // Counter-up animation for stat numbers
  function animateCounter(el: HTMLElement) {
    const target = parseInt(el.dataset.target || "0", 10);
    const suffix = el.querySelector("span")?.textContent ?? "";
    const duration = 1500;
    const start = performance.now();

    function tick(now: number) {
      const elapsed = now - start;
      const progress = Math.min(elapsed / duration, 1);
      const ease = 1 - Math.pow(1 - progress, 3); // ease-out cubic
      const value = Math.round(ease * target);
      el.childNodes[0].textContent = String(value);
      if (progress < 1) requestAnimationFrame(tick);
    }
    requestAnimationFrame(tick);
  }

  const statNums = document.querySelectorAll<HTMLElement>(".stat-num[data-target]");
  const counterObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          animateCounter(entry.target as HTMLElement);
          counterObserver.unobserve(entry.target);
        }
      });
    },
    { threshold: 0.5 }
  );
  statNums.forEach((el) => counterObserver.observe(el));
</script>
